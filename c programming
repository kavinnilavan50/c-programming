#include <stdio.h>
#include <stdlib.h>

int main() {
    FILE *file;
    int choice;
    char name[50];
    int roll;
    char status;

    while (1) {
        printf("\n--- Mini Attendance Tracker ---\n");
        printf("1. Mark Attendance\n");
        printf("2. View Attendance\n");
        printf("3. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        if (choice == 1) {
            file = fopen("attendance.txt", "a");

            printf("Enter student name: ");
            scanf("%s", name);

            printf("Enter roll number: ");
            scanf("%d", &roll);

            printf("Enter status (P/A): ");
            scanf(" %c", &status);

            fprintf(file, "Name: %s | Roll: %d | Status: %c\n", name, roll, status);
            fclose(file);

            printf("Attendance marked successfully!\n");
        }
        else if (choice == 2) {
            file = fopen("attendance.txt", "r");

            if (file == NULL) {
                printf("No records found!\n");
                continue;
            }

            char ch;
            printf("\n--- Attendance Records ---\n");
            while ((ch = fgetc(file)) != EOF) {
                printf("%c", ch);
            }

            fclose(file);
        }
        else if (choice == 3) {
            printf("Exiting program...\n");
            break;
        }
        else {
            printf("Invalid choice! Try again.\n");
        }
    }

    return 0;
}
